#!/bin/bash
#SBATCH --job-name=low_hyp_res_collages
#SBATCH --account=cobrinik_1090
#SBATCH --partition=epyc-64
#SBATCH --qos=normal
#SBATCH --mem=64G
#SBATCH --cpus-per-task=4
#SBATCH --time=08:00:00
#SBATCH --output=/project2/cobrinik_1090/external_rb_scrnaseq_proj/logs/low_hypoxia_res_collages_%j.log
#SBATCH --error=/project2/cobrinik_1090/external_rb_scrnaseq_proj/logs/low_hypoxia_res_collages_%j.err

# Build heatmap_collages_low_hypoxia_by_res: two marker-heatmap collages per
# sample on the persisted *_hypoxia_low_seu.rds --
#   1. the split's anchor resolution (r_flag, whose clusters were dropped)
#   2. r_flag + 0.4
# or a fixed 0.6 / 1.0 pair when the sample flagged nothing.
#
# The existing heatmap_collages_low_hypoxia is pinned to SCT_snn_res.0.6 for every
# sample (dummy_cluster_order hardcodes that column), so it never shows the
# clustering the drop was actually made on.
#
# NOTE both collages are POST-exclusion: the low object already has the flagged
# cells removed, and subset_seu_by_expression re-clustered the survivors. The
# before/after view at the moment of the drop is the separate set of stage
# collages emitted by split_hypoxia_by_clusters (*_hypoxia_rflag<R>_{before,after}
# and *_hypoxia_recluster<R>).
#
# No split rebuild needed: the anchor is recovered from the existing split logs via
# pick_hypoxia_anchor(), the same function split_hypoxia_by_clusters() uses.

module load r/4.4.1
export LD_LIBRARY_PATH="$HOME/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
cd /project2/cobrinik_1090/external_rb_scrnaseq_proj

# Install for the crew workers.
#
# Do NOT run devtools::document() and assume the exports land: this package's
# NAMESPACE is HAND-MAINTAINED (it lacks roxygen2's "# Generated by roxygen2"
# header), so roxygen2 refuses to rewrite it and @export tags are silently
# ignored. New exports must be added to NAMESPACE by hand.
#
# Verify against the EXPORTED surface (getNamespaceExports), not
# exists(..., asNamespace=), which also sees unexported internals and therefore
# passes even when the pipeline -- which reaches these via library(numbatHelpers)
# -- cannot call them. That false pass is exactly what let job 10215851 run every
# branch into "could not find function 'plot_hypoxia_low_res_collages'".
Rscript -e 'suppressMessages(devtools::install_local("/project2/cobrinik_1090/rpkgs/numbat_helpers", force=TRUE, upgrade="never", quiet=TRUE)); ex <- getNamespaceExports("numbatHelpers"); need <- c("plot_hypoxia_low_res_collages","pick_hypoxia_anchor","split_hypoxia_by_clusters"); miss <- setdiff(need, ex); if (length(miss)) stop("NOT EXPORTED: ", paste(miss, collapse=", ")); cat("numbatHelpers installed; exports present:", paste(need, collapse=", "), "\n")' \
  || { echo "FATAL: numbatHelpers install/export-verify failed -- aborting before tar_make"; exit 1; }

Rscript run_targets_bg.R heatmap_collages_low_hypoxia_by_res
