#!/bin/bash
#SBATCH --job-name=low_hyp_res_collages
#SBATCH --account=cobrinik_1090
#SBATCH --partition=epyc-64
#SBATCH --qos=normal
#SBATCH --mem=64G
#SBATCH --cpus-per-task=4
#SBATCH --time=12:00:00
#SBATCH --output=/project2/cobrinik_1090/external_rb_scrnaseq_proj/logs/low_hypoxia_res_collages_%j.log
#SBATCH --error=/project2/cobrinik_1090/external_rb_scrnaseq_proj/logs/low_hypoxia_res_collages_%j.err

# Build heatmap_collages_low_hypoxia_by_res: marker-heatmap + phase-scatter
# collages of the low-hypoxia object across the CAPPED resolution sweep
# 0.2 .. 0.8 (by 0.2), one per resolution per sample, on the persisted
# *_hypoxia_low_seu.rds. Output:
#   results/<SRX>_hypoxia_low_seu.rds__filtered_res<R>_heatmap_phase_scatter_patchwork.pdf
# No clone-tree panel (nb_paths = NULL) -- the sweep is about the clustering.
#
# Two small-cluster mitigations vs the earlier 0.2..1.2 sweep:
#   (1) capped at 0.8 (res >= 1.0 is where the few <20-cell clusters appear);
#   (2) recompute_pca = TRUE: the PCA is recomputed on the surviving low-hypoxia
#       cells and every resolution re-clustered on it, instead of the persisted
#       columns clustered in the inherited pre-split PCA.
#
# Then re-sync everything to Google Drive via hypoxia_rebuilt_gdrive, which groups
# the new collages under low_hypoxia_by_res/{paper_retained,other}/.

module load r/4.4.1
module load rclone
export LD_LIBRARY_PATH="$HOME/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
cd /project2/cobrinik_1090/external_rb_scrnaseq_proj

# Install for the crew workers.
#
# Do NOT run devtools::document() and assume the exports land: this package's
# NAMESPACE is HAND-MAINTAINED (no roxygen2 "# Generated by roxygen2" header), so
# roxygen2 refuses to rewrite it and @export tags are silently ignored. New
# exports must be added to NAMESPACE by hand. (This change adds no new export --
# only a `resolutions` arg to the already-exported plot_hypoxia_low_res_collages.)
#
# Verify against the EXPORTED surface (getNamespaceExports), not
# exists(..., asNamespace=), which also sees unexported internals.
Rscript -e 'suppressMessages(devtools::install_local("/project2/cobrinik_1090/rpkgs/numbat_helpers", force=TRUE, upgrade="never", quiet=TRUE)); ex <- getNamespaceExports("numbatHelpers"); need <- c("plot_hypoxia_low_res_collages","pick_hypoxia_anchor","split_hypoxia_by_clusters"); miss <- setdiff(need, ex); if (length(miss)) stop("NOT EXPORTED: ", paste(miss, collapse=", ")); if (!"resolutions" %in% names(formals(numbatHelpers::plot_hypoxia_low_res_collages))) stop("plot_hypoxia_low_res_collages lacks the `resolutions` arg -- stale install"); cat("numbatHelpers installed; resolutions arg present\n")' \
  || { echo "FATAL: numbatHelpers install/export-verify failed -- aborting before tar_make"; exit 1; }

# The target command changed (2-res anchor pair -> full 0.2..1.2 sweep), which
# already marks it outdated, but invalidate the base target + all dynamic branches
# explicitly so every per-sample branch re-runs with the new resolutions.
Rscript -e '
suppressPackageStartupMessages(library(targets)); tar_config_set(store="_targets_r431")
meta <- tar_meta(fields="name", complete_only=FALSE)
pat  <- "^heatmap_collages_low_hypoxia_by_res(_[0-9a-f]+)?$"
to_inv <- meta$name[grepl(pat, meta$name)]
tar_invalidate(any_of(to_inv))
cat("invalidated:", length(to_inv), "by_res targets/branches\n")
' \
  || { echo "FATAL: invalidation step failed -- aborting before tar_make"; exit 1; }

# Build the sweep, then re-sync to Drive (hypoxia_rebuilt_gdrive, cue=always,
# deployment=main; rclone copy only re-uploads files that changed).
Rscript run_targets_bg.R heatmap_collages_low_hypoxia_by_res hypoxia_rebuilt_gdrive

# Slack ping on completion (best-effort; safe no-op if webhook absent).
if [ -f "$HOME/.slack_webhook" ]; then
  N=$(ls results/*_hypoxia_low_seu.rds__filtered_res*_heatmap_phase_scatter_patchwork.pdf 2>/dev/null | wc -l)
  curl -s -X POST -H 'Content-type: application/json' \
    --data "{\"text\":\"low_hypoxia_res_collages ($SLURM_JOB_ID) done: $N low-hypoxia res-sweep collages on disk, synced to Drive\"}" \
    "$(cat "$HOME/.slack_webhook")" >/dev/null || true
fi
