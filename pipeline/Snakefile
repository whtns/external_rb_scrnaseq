## Configuration file
import os
import sys
import shlex

if not os.path.isfile("./config.yaml"):
    sys.exit("Make sure there is a config.yaml file in " + os.getcwd() + " or specify one with the --configfile commandline parameter.")

configfile: "./config.yaml"

## Make sure that all expected variables from the config file are in the config dictionary
configvars = [
    'metatsv', 'ncores', 'output', 'Rbin', 'R_LIBS_USER',
    'numbat_t', 'gamma', 'max_entropy', 'min_LLR', 'max_iter',
    'read_prop', 'tau', 'cell_ceiling', 'gmap', 'snpvcf',
    'paneldir', 'sridhar_ref_path', 'cellranger_output',
    'subset_bad_cell_types_default', 'subset_bad_cell_types_by_sample',
    'celltype_ref', 'numbat_sridhar_dirname',
    'FASTQ', 'cellranger_transcriptome'
]
for k in configvars:
    if k not in config:
        config[k] = None

## Sanitize the metadata file path
def sanitizefile(str):
    if str is None:
        str = ''
    return str

config['metatsv'] = sanitizefile(config['metatsv'])

## Read metadata
if not os.path.isfile(config["metatsv"]):
    sys.exit("Metadata file " + config["metatsv"] + " does not exist.")

import re
import pandas as pd
from pathlib import Path

table_samples = pd.read_csv(config["metatsv"], sep="\t")

## Sample discovery: union of samples found in the FASTQ directory and existing
## cellranger output directories, filtered to those present in the metadata.
cellranger_base  = config["cellranger_output"]
fastq_base       = config.get("FASTQ", "../data/FASTQ")
metadata_samples = set(table_samples["Experiment"].tolist())

_samples = set()

## Discover from FASTQ subdirectories (samples not yet run through cellranger)
_fastq_path = Path(os.path.abspath(fastq_base))
if _fastq_path.exists():
    for _d in sorted(_fastq_path.iterdir()):
        if _d.is_dir() and _d.name in metadata_samples:
            _samples.add(_d.name)

## Also include samples with existing cellranger output (for resuming partial runs)
_cr_path = Path(cellranger_base)
if _cr_path.exists():
    for _d in sorted(_cr_path.iterdir()):
        if _d.is_dir() and _d.name in metadata_samples:
            _bam = _d / "outs" / "possorted_genome_bam.bam"
            if _bam.exists():
                _samples.add(_d.name)

samples = sorted(_samples)
if len(samples) == 0:
    sys.exit(
        "No samples found in FASTQ directory (" + fastq_base + ") "
        "or cellranger output (" + cellranger_base + ") that match the metadata."
    )

## Optional: limit which samples to process (comma-separated string or list in config)
_run_samples_cfg = config.get("run_samples", None)
if _run_samples_cfg not in [None, "", "None", "none"]:
    if isinstance(_run_samples_cfg, str):
        _run_samples_cfg = [s.strip() for s in _run_samples_cfg.split(",")]
    _filter_set = set(_run_samples_cfg)
    samples = [s for s in samples if s in _filter_set]
    if len(samples) == 0:
        sys.exit("No matching samples after run_samples filter: " + str(_run_samples_cfg))

## Sanitize output directory path
def getpath(str):
    if str in ['', '.', './']:
        return ''
    if str.startswith('./'):
        regex = re.compile(r'^\./?')
        str = regex.sub('', str)
    if not str.endswith('/'):
        str += '/'
    return str

outputdir = os.path.abspath(getpath(config["output"])) + "/"
numbat_sridhar_dirname = config.get("numbat_sridhar_dirname", "numbat_sridhar_mergerd")
numbat_sridhar_dir = outputdir + getpath(numbat_sridhar_dirname)

## Define the R binary
Rbin = config["Rbin"]

## Singularity container — used for all R rules
_sif = "/project2/cobrinik_1090/external_rb_scrnaseq_proj/pipeline/containers/numbat-pipeline.sif"
container_R      = "apptainer exec --bind /project2 " + _sif + " /usr/bin/R"
container_Rscript = "apptainer exec --bind /project2 " + _sif + " /usr/bin/Rscript"

## Optional project-local R library path
RlibsUser = config.get("R_LIBS_USER", None)
if RlibsUser not in [None, "", "None", "none"]:
    RlibsUser = os.path.abspath(os.path.normpath(getpath(RlibsUser)))
    shell.prefix("export R_LIBS_USER=" + shlex.quote(RlibsUser) + "; ")

## Per-sample helper functions
def parse_bool(value, default=True):
    if value is None:
        return default
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return value != 0
    value_str = str(value).strip().lower()
    if value_str in ["true", "t", "1", "yes", "y"]:
        return True
    if value_str in ["false", "f", "0", "no", "n"]:
        return False
    return default

def subset_bad_cell_types_for_sample(wildcards):
    default_value = parse_bool(config.get("subset_bad_cell_types_default", True), True)
    per_sample = config.get("subset_bad_cell_types_by_sample", {})
    if isinstance(per_sample, dict) and wildcards.sample in per_sample:
        return parse_bool(per_sample[wildcards.sample], default_value)
    if "subset_bad_cell_types" in table_samples.columns:
        sample_rows = table_samples[table_samples.Experiment == wildcards.sample]
        if len(sample_rows) > 0:
            return parse_bool(sample_rows.subset_bad_cell_types.values[0], default_value)
    return default_value

def max_entropy_for_sample(wildcards):
    default_value = config.get("max_entropy", 0.7)
    per_sample = config.get("max_entropy_by_sample", {})
    if isinstance(per_sample, dict) and wildcards.sample in per_sample:
        return per_sample[wildcards.sample]
    return default_value

def bam_for_sample(wildcards):
    return outputdir + "cellranger/" + wildcards.sample + "/outs/possorted_genome_bam.bam"

def barcodes_for_sample(wildcards):
    return outputdir + "cellranger/" + wildcards.sample + "/outs/filtered_feature_bc_matrix/barcodes.tsv.gz"

def matrix_dir_for_sample(wildcards):
    return outputdir + "cellranger/" + wildcards.sample + "/outs/filtered_feature_bc_matrix/"

def matrix_file_for_sample(wildcards):
    return outputdir + "cellranger/" + wildcards.sample + "/outs/filtered_feature_bc_matrix/matrix.mtx.gz"

## ------------------------------------------------------------------------------------ ##
## Target definitions
## ------------------------------------------------------------------------------------ ##

rule all:
    input:
        expand(numbat_sridhar_dir + "{sample}/done.txt", sample=samples),
        expand(numbat_sridhar_dir + "{sample}_numbat.rds", sample=samples)

## ------------------------------------------------------------------------------------ ##
## Step 0: Cell Ranger count
##
## Aligns FASTQ reads to the reference transcriptome and produces the feature-barcode
## matrix and position-sorted BAM consumed by all downstream steps.
## FASTQs must be organised as data/FASTQ/{sample}/{sample}_S1_L001_R[12]_001.fastq.gz
## ------------------------------------------------------------------------------------ ##

rule cellranger:
    input:
        fastqdir = fastq_base + "/{sample}"
    output:
        bam      = outputdir + "cellranger/{sample}/outs/possorted_genome_bam.bam",
        barcodes = outputdir + "cellranger/{sample}/outs/filtered_feature_bc_matrix/barcodes.tsv.gz",
        matrix   = outputdir + "cellranger/{sample}/outs/filtered_feature_bc_matrix/matrix.mtx.gz"
    log:
        outputdir + "logs/cellranger_{sample}.log"
    benchmark:
        outputdir + "benchmarks/cellranger_{sample}.txt"
    threads:
        config.get("cellranger_cores", 16)
    resources:
        mem_mb = config.get("cellranger_mem_mb", 120000),
        time   = "24:00:00"
    params:
        transcriptome  = config["cellranger_transcriptome"],
        cellranger_dir = outputdir + "cellranger",
        abs_fastqdir   = lambda wildcards: os.path.abspath(fastq_base + "/" + wildcards.sample),
        localmem       = lambda wildcards, resources: resources.mem_mb // 1000
    shell:
        '''
        export PATH=/apps/generic/cellranger/8.0.1/bin:$PATH
        echo "cellranger version:" > {log}; cellranger --version >> {log}
        rm -rf {params.cellranger_dir}/{wildcards.sample}
        cd {params.cellranger_dir}
        cellranger count \
            --id={wildcards.sample} \
            --fastqs={params.abs_fastqdir} \
            --sample={wildcards.sample} \
            --transcriptome={params.transcriptome} \
            --localcores={threads} \
            --localmem={params.localmem} \
            --create-bam=true >> {log} 2>&1
        '''

## ------------------------------------------------------------------------------------ ##
## Step 1a: Pileup
##
## Counts alleles at heterozygous SNP positions using cellsnp-lite.
## Output sentinel (cellSNP.base.vcf) lets Snakemake skip this ~1-hour step on
## resume if it already completed successfully.
## ------------------------------------------------------------------------------------ ##

rule pileup:
    input:
        bam      = outputdir + "cellranger/{sample}/outs/possorted_genome_bam.bam",
        barcodes = outputdir + "cellranger/{sample}/outs/filtered_feature_bc_matrix/barcodes.tsv.gz"
    output:
        sentinel = outputdir + "numbat/{sample}/pileup/{sample}/cellSNP.base.vcf"
    log:
        outputdir + "logs/pileup_{sample}.log"
    benchmark:
        outputdir + "benchmarks/pileup_{sample}.txt"
    threads:
        config.get("pileup_cores", 16)
    resources:
        mem_mb = 32000,
        time   = "08:00:00"
    params:
        gmap   = config["gmap"],
        snpvcf = config["snpvcf"],
        outdir = outputdir + "numbat/{sample}",
        script = "scripts/pileup_and_phase.R"
    shell:
        '''
        {container_Rscript} {params.script} \
            --label {wildcards.sample} \
            --samples {wildcards.sample} \
            --bams {input.bam} \
            --barcodes {input.barcodes} \
            --outdir {params.outdir} \
            --gmap {params.gmap} \
            --snpvcf {params.snpvcf} \
            --paneldir /dev/null \
            --ncores {threads} \
            --pileup_only > {log} 2>&1
        '''

## ------------------------------------------------------------------------------------ ##
## Step 1b: Phasing and allele count generation
##
## Reads the cellsnp-lite pileup, runs numbat::genotype() + Eagle2 phasing, and
## writes the allele count table consumed by the numbat CNV inference step.
## Split from pileup so Snakemake can resume here without re-running cellsnp-lite.
## ------------------------------------------------------------------------------------ ##

rule phase_and_count:
    input:
        sentinel = outputdir + "numbat/{sample}/pileup/{sample}/cellSNP.base.vcf"
    output:
        allele_df     = outputdir + "numbat/{sample}_allele_counts.tsv.gz",
        phased_output = outputdir + "numbat/{sample}/phasing/{sample}_chr22.phased.vcf.gz"
    log:
        outputdir + "logs/phase_and_count_{sample}.log"
    benchmark:
        outputdir + "benchmarks/phase_and_count_{sample}.txt"
    threads:
        config.get("phase_cores", 16)
    resources:
        mem_mb = 32000,
        time   = "08:00:00"
    params:
        gmap     = config["gmap"],
        paneldir = config["paneldir"],
        outdir   = outputdir + "numbat/{sample}",
        script   = "scripts/phase_and_count.R",
        intermediate_allele_df = outputdir + "numbat/{sample}/{sample}_allele_counts.tsv.gz"
    shell:
        '''
        {container_Rscript} {params.script} \
            --label {wildcards.sample} \
            --samples {wildcards.sample} \
            --outdir {params.outdir} \
            --gmap {params.gmap} \
            --paneldir {params.paneldir} \
            --ncores {threads} > {log} 2>&1;
        cp {params.intermediate_allele_df} {output.allele_df}
        '''

## ------------------------------------------------------------------------------------ ##
## Step 2: Seurat object construction
##
## Builds a Seurat single-cell object from the cellranger filtered feature-barcode
## matrix and annotates cell types using a provided reference. Numbat uses this
## object to stratify cells (e.g. to exclude known normal cell types as reference)
## and to initialise clone detection.
## ------------------------------------------------------------------------------------ ##

rule seurat:
    input:
        matrix_file = outputdir + "cellranger/{sample}/outs/filtered_feature_bc_matrix/matrix.mtx.gz",
        script      = "scripts/process_seurat.R"
    output:
        seu_path = outputdir + "seurat/{sample}_seu.rds"
    log:
        outputdir + "logs/seurat_{sample}.log"
    benchmark:
        outputdir + "benchmarks/seurat_{sample}.txt"
    threads:
        config.get("seurat_cores", 4)
    resources:
        mem_mb = 32000,
        time   = "04:00:00"
    params:
        matrix_dir   = outputdir + "cellranger/{sample}/outs/filtered_feature_bc_matrix/",
        celltype_ref = config["celltype_ref"]
    shell:
        '''{container_R} CMD BATCH --no-restore --no-save "--args matrix_dir='{params.matrix_dir}' seu_path='{output.seu_path}' celltype_ref='{params.celltype_ref}'" {input.script} {log}'''

## ------------------------------------------------------------------------------------ ##
## Step 3: Numbat CNV inference
##
## Runs the core numbat algorithm. It jointly models allele imbalance (from the
## phased allele counts) and expression changes (from the feature matrix) to infer
## copy number events per cell, assign cells to tumour clones, and reconstruct the
## clonal phylogeny. Outputs a done.txt sentinel file when finished.
## ------------------------------------------------------------------------------------ ##

rule numbat_sridhar:
    input:
        allele_df   = outputdir + "numbat/{sample}_allele_counts.tsv.gz",
        matrix_file = outputdir + "cellranger/{sample}/outs/filtered_feature_bc_matrix/matrix.mtx.gz",
        seu_path    = outputdir + "seurat/{sample}_seu.rds",
        script      = "scripts/run_numbat.R"
    output:
        done_file = numbat_sridhar_dir + "{sample}/done.txt"
    log:
        numbat_sridhar_dir + "{sample}/snakemake_numbat.log"
    benchmark:
        numbat_sridhar_dir + "{sample}/benchmark_numbat.txt"
    threads:
        config.get("numbat_cores", 16)
    resources:
        mem_mb = config.get("numbat_mem_mb", 65536),
        time   = "24:00:00"
    params:
        num_clones            = lambda wildcards: table_samples[table_samples.Experiment == wildcards.sample].num_clone.values[0],
        subset_bad_cell_types = subset_bad_cell_types_for_sample,
        numbat_t              = config["numbat_t"],
        gamma                 = config["gamma"],
        numbatdir             = numbat_sridhar_dir,
        max_entropy           = max_entropy_for_sample,
        min_LLR               = config["min_LLR"],
        max_iter              = config["max_iter"],
        read_prop             = config["read_prop"],
        tau                   = config["tau"],
        cell_ceiling          = config["cell_ceiling"],
        prof                  = numbat_sridhar_dir + "{sample}/log.prof",
        ref_path              = config["sridhar_ref_path"],
        mem_kb                = lambda wildcards, resources: resources.mem_mb * 1024 * 2
    shell:
        '''
        ulimit -v {params.mem_kb};
        {container_R} CMD BATCH --no-restore --no-save \
        "--args seu_path='{input.seu_path}' ref_path='{params.ref_path}' \
        t='{params.numbat_t}' gamma='{params.gamma}' tau='{params.tau}' \
        init_k='{params.num_clones}' read_prop='{params.read_prop}' \
        subset_bad_cell_types='{params.subset_bad_cell_types}' \
        max_iter='{params.max_iter}' min_LLR='{params.min_LLR}' \
        cell_ceiling='{params.cell_ceiling}' max_entropy='{params.max_entropy}' \
        allele_df='{input.allele_df}' matrix_file='{input.matrix_file}' \
        out_dir='{params.numbatdir}/{wildcards.sample}' ncores='{threads}' \
        rprof_out='{params.prof}'" {input.script} {log}
        '''

## ------------------------------------------------------------------------------------ ##
## Step 4: Package numbat results into an RDS file
##
## Reads the completed numbat output directory and serialises the key results
## (clone assignments, CNV calls, phylogeny) into a single .rds file for
## downstream analysis in R.
## ------------------------------------------------------------------------------------ ##

rule numbat_sridhar_rds:
    input:
        done_file = numbat_sridhar_dir + "{sample}/done.txt"
    output:
        numbat_sridhar_dir + "{sample}_numbat.rds"
    log:
        numbat_sridhar_dir + "{sample}/snakemake_numbat_rds.log"
    benchmark:
        numbat_sridhar_dir + "{sample}/benchmark_numbat_rds.txt"
    threads:
        1
    resources:
        mem_mb = 8000,
        time   = "01:00:00"
    params:
        script = "scripts/process_numbat_rds.R"
    shell:
        '''{container_R} CMD BATCH --no-restore --no-save "--args done_file='{input.done_file}'" {params.script} {log}'''

## ------------------------------------------------------------------------------------ ##
## Success and failure messages
## ------------------------------------------------------------------------------------ ##

onsuccess:
    print("Success! The Snakemake workflow is completed.")

onerror:
    print("Error! The Snakemake workflow aborted.")
